# Copy this file to .env.local (local dev) and fill in your values, or add these
# in Vercel → Settings → Environment Variables (production).
# .env.local is gitignored — never commit real keys.
# Everything is OPTIONAL: each feature degrades gracefully when its vars are unset.

# ── Authentication (NextAuth + Google sign-in) ───────────────────────────────
NEXTAUTH_SECRET=your_long_random_string     # e.g. `openssl rand -base64 32`
NEXTAUTH_URL=https://gold-intelligence-os.vercel.app
GOOGLE_CLIENT_ID=                           # Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_SECRET=

# ── AI (Gemini) — recommendations, daily brief, AI Council briefing ──────────
GEMINI_API_KEY=your_gemini_api_key_here     # https://aistudio.google.com/
GEMINI_MODEL=gemini-2.5-flash               # optional override

# ── Telegram alerts — AI Council alert (🔔) + signal broadcast ───────────────
# Bot token from @BotFather. CHANNEL_ID = "@yourchannel" or numeric "-100...".
# Without these, /api/council/alert returns a preview instead of sending.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Research DB — durable Self-Learning journal (council votes) ──────────────
# On Vercel the local-file journal is ephemeral. Set ONE of these to persist:
#   • Vercel Postgres / Neon → POSTGRES_URL (added automatically by the integration)
#   • Upstash Redis          → the two REST vars below
POSTGRES_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── MT5 bridge (optional) — the EA in MetaTrader must use the same key ───────
MT5_API_KEY=mt5-bridge-key

# ── Admin approval emails (SMTP via Gmail) — optional ────────────────────────
ADMIN_EMAILS=                # comma-separated admin emails (elevated access)
ADMIN_NOTIFY_EMAIL=          # where new-signup notifications go
SMTP_GMAIL_USER=             # gmail address used to send mail
SMTP_GMAIL_PASS=             # gmail App Password (not your login password)

# ── Optional hardening ───────────────────────────────────────────────────────
CRON_SECRET=                 # if set, Vercel Cron sends it as a Bearer header
