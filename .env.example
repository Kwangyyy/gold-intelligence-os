# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real API keys.

# Google Gemini API Key (required for AI features)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# MT5 Bridge API Key (optional — set a strong random string)
# The EA in MetaTrader must use the same key in its settings.
MT5_API_KEY=mt5-bridge-key
